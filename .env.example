RENDER_API_KEY=rnd_your-render-api-key
WORKFLOW_SLUG=research-agent-workflow
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AGENT_TEMPERATURE=0.3
EXA_API_KEY=your-exa-api-key

# History (optional: omit to disable research history sidebar)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# LangSmith (optional: omit to disable tracing + feedback)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls_your-langsmith-api-key
LANGCHAIN_PROJECT=research-agent

# Kill switch: set to false to disable POST /feedback without code changes
FEATURE_LANGSMITH_FEEDBACK=true
